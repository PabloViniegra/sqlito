{
  "name": "sqlito",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.tsx",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "oxlint",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "bench": "node scripts/bench-cold-start.mjs",
    "db:seed": "node scripts/seed-sample-db.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint"
    ],
    "*.{ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "cli-truncate": "^6.1.0",
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "prettier": "^3.6.2",
    "tsx": "^4.22.5",
    "typescript": "~6.0.2",
    "vitest": "^4.1.9"
  }
}
