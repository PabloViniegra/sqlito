{
  "name": "@pabloviniegra/sqlito",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "bin": {
    "sqlito": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/main.tsx",
    "build": "tsup",
    "typecheck": "tsc -b",
    "lint": "oxlint",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "bench": "node scripts/bench-cold-start.mjs",
    "gate": "pnpm exec lint-staged && pnpm typecheck && pnpm test:run && pnpm build && pnpm bench",
    "db:seed": "node scripts/seed-sample-db.mjs",
    "prepare": "husky",
    "doctor": "npx react-doctor@latest"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint"
    ],
    "*.{ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "cli-truncate": "^6.1.0",
    "clipboardy": "^5.3.1",
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "prettier": "^3.6.2",
    "react-doctor": "^0.7.1",
    "semantic-release": "^25.0.5",
    "tsup": "^8.5.1",
    "tsx": "^4.22.5",
    "typescript": "~6.0.2",
    "vitest": "^4.1.9"
  }
}
